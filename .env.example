# OpenBoss 环境变量配置模板
# 复制此文件为 .env 并填写实际值：cp .env.example .env

# ══════════════════════════════════════════════════════════
# 1. AI / Claude 配置
# ══════════════════════════════════════════════════════════

# Claude Code CLI API Key（Sub-Agent 执行环境）
CLAUDE_API_KEY=your_claude_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude Code CLI 路径（留空则使用 PATH 中的 claude）
CLAUDE_CLI_PATH=

# ══════════════════════════════════════════════════════════
# 2. tmux 配置
# ══════════════════════════════════════════════════════════

# tmux 主会话名称
TMUX_SESSION_NAME=openboss

# tmux 最低版本要求
TMUX_MIN_VERSION=3.2

# ══════════════════════════════════════════════════════════
# 3. Git 配置
# ══════════════════════════════════════════════════════════

# Git 提交者名称（Agent 自动提交时使用）
GIT_AUTHOR_NAME=OpenBoss Agent

# Git 提交者邮箱
GIT_AUTHOR_EMAIL=openboss-agent@localhost

# Git 操作最大重试次数
GIT_MAX_RETRIES=3

# ══════════════════════════════════════════════════════════
# 4. Master Agent 调度配置
# ══════════════════════════════════════════════════════════

# 最大并发 Sub-Agent 数量
MAX_CONCURRENT_AGENTS=3

# Sub-Agent 执行超时时间（秒）
AGENT_TIMEOUT=1800

# 进度轮询间隔（秒）
POLL_INTERVAL=10

# 任务失败后最大重试次数
TASK_MAX_RETRIES=1

# ══════════════════════════════════════════════════════════
# 5. OpenClaw 监控配置
# ══════════════════════════════════════════════════════════

# 进程检查间隔（秒）
OPENCLAW_CHECK_INTERVAL=30

# CPU 使用率告警阈值（百分比）
OPENCLAW_MAX_CPU_PERCENT=80

# 内存使用告警阈值（MB）
OPENCLAW_MAX_MEMORY_MB=2048

# 告警重试次数
OPENCLAW_ALERT_RETRY=3

# 告警重试间隔（秒）
OPENCLAW_ALERT_RETRY_INTERVAL=60

# ══════════════════════════════════════════════════════════
# 6. 告警通知 Webhook
# ══════════════════════════════════════════════════════════

# 企业微信机器人 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# 钉钉机器人 Webhook URL
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# Slack Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ══════════════════════════════════════════════════════════
# 7. Web 面板配置
# ══════════════════════════════════════════════════════════

# Web 面板监听地址
API_HOST=0.0.0.0

# Web 面板监听端口
API_PORT=8000

# ══════════════════════════════════════════════════════════
# 8. 路径配置
# ══════════════════════════════════════════════════════════

# 项目根目录（留空则使用当前工作目录）
PROJECT_ROOT=

# 日志目录
LOG_DIR=./logs

# 数据目录
DATA_DIR=./data

# 备份目录
BACKUP_DIR=./data/backup

# ══════════════════════════════════════════════════════════
# 9. 开发调试
# ══════════════════════════════════════════════════════════

# DEBUG 模式（true/false）
DEBUG=false

# 日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）
LOG_LEVEL=INFO
